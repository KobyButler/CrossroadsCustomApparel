# DB: use SQLite locally; use Postgres in prod (set DATABASE_URL accordingly)
DATABASE_URL="file:./dev.db"

PORT=4000
JWT_SECRET="devsecret_change_me"

# CORS allowed origins (comma-separated); include your web app origin(s)
CORS_ORIGINS="http://localhost:3000"

# S&S Activewear API
SS_USER=""          # your S&S account number
SS_API_KEY=""       # your S&S API key
SS_ENABLE=false     # set true to actually post orders

# SanMar SOAP Web Services
SANMAR_CUSTOMER_NUMBER=""     # integer customer number
SANMAR_USERNAME=""            # provided by sanmar
SANMAR_PASSWORD=""            # provided by sanmar
SANMAR_WSDL_URL=""            # provided by sanmar (UAT/prod); leave blank for dry-run
SANMAR_ENABLE=false           # set true to actually submit POs

# Optional: SanMar SFTP (file-drop) path/creds if you choose that route later
SANMAR_SFTP_HOST=""
SANMAR_SFTP_USER=""
SANMAR_SFTP_PASSWORD=""
SANMAR_SFTP_ENABLE=false
